# ═══════════════════════════════════════════════════
#  TRINETRA RAKSHAK -- Environment Variables
# ═══════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your credentials.
#  NEVER commit the .env file to version control.
#
# --- TELEGRAM ---
#  Create a bot via @BotFather on Telegram.
#  Get your chat ID by messaging @userinfobot.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- TWILIO (SMS + WhatsApp) ---
#  Sign up at https://www.twilio.com/console
#  Get SID and Auth Token from the dashboard.
#  Buy or use a trial phone number for TWILIO_FROM_NUMBER.
#  ALERT_PHONE_NUMBER is the recipient (your phone) in E.164 format.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_PHONE_NUMBER=

# --- ANTHROPIC (Claude AI) ---
#  Get an API key at https://console.anthropic.com/
#  Used for the AI Threat Analyst chatbot (claude-haiku-4-5-20251001).
ANTHROPIC_API_KEY=

# --- SUPABASE (Real-time Database) ---
#  Create a project at https://supabase.com/dashboard
#  Find URL and anon key in Settings > API.
#  Create the threat_logs table using the SQL in command_center/src/lib/supabase.js.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
